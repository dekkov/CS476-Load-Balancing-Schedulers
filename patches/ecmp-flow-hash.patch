+        if (m_flowEcmpRouting && allRoutes.size() > 1)
+        {
+            // Per-flow ECMP: hash on 5-tuple (srcIP, dstIP, protocol, srcPort, dstPort)
+            uint32_t srcAddr = 0;
+            uint32_t dstAddr = dest.Get();
+            uint8_t protocol = 0;
+            uint16_t srcPort = 0;
